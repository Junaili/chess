# Credentials for the LIVE end-to-end integration tests (npm run test:live).
# Copy to `.env.test` (git-ignored) and fill in. Without this file, the live
# specs SKIP automatically — the unit and offline E2E suites still run.
#
# Use throwaway AGS accounts created against the chess namespace (you can make
# them from the in-app "Create Free Account" screen). The tests sign in with the
# AGS username/email + password grant.

# Primary test account — required for all live specs.
TEST_USER_1_IDENTIFIER=your-test-username-or-email
TEST_USER_1_PASSWORD=your-test-password

# Second test account — only needed for the two-player online match test
# (tests/e2e/live/online-match.live.spec.js). Leave unset to skip just that one.
TEST_USER_2_IDENTIFIER=your-second-test-username-or-email
TEST_USER_2_PASSWORD=your-second-test-password
