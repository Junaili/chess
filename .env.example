ACCELBYTE_BASE_URL=https://seal-chessags.prod.gamingservices.accelbyte.io
ACCELBYTE_NAMESPACE=seal-chessags
ACCELBYTE_CLIENT_ID=4d98466a671d4172aa98f9a3f1fa29d1

VITE_ACCELBYTE_BASE_URL=https://seal-chessags.prod.gamingservices.accelbyte.io
VITE_ACCELBYTE_NAMESPACE=seal-chessags
VITE_ACCELBYTE_CLIENT_ID=4d98466a671d4172aa98f9a3f1fa29d1

# Stripe's publishable key (pk_...) is not secret — it's meant to ship in
# frontend JS — but it must match whichever STRIPE_SECRET_KEY the Extend
# service is running with (both test-mode or both live-mode). Powers the
# embedded Checkout mounted in the Club screen (src/club.js).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Change this to your machine's local IP address (or https://localhost:8808/ if testing locally only)
# Mac: run `ipconfig getifaddr en0` to find your IP
# Windows: run `ipconfig` and look for IPv4 Address
VITE_ACCELBYTE_REDIRECT_URI=https://localhost:8808/

# Optional but required for production-grade relayed video calls. This must be
# a same-origin or CORS-enabled HTTPS endpoint that returns short-lived TURN
# credentials; never place a long-lived TURN secret in a VITE_ variable.
# Response: {"iceServers":[{"urls":["turn:turn.example.com:3478?transport=udp","turns:turn.example.com:5349"],"username":"...","credential":"..."}],"ttl":600}
VITE_RTC_ICE_CONFIG_URL=https://YOUR_SUBDOMAIN.prod.gamingservices.accelbyte.io/turnmanager/turn
