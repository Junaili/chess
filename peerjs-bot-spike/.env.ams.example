# Config baked into the AMS upload bundle (build-bundle.sh copies this to the
# bundle's app/.env). AMS development build-configs have no env-var field, so the
# DS reads its config from here. Copy to .env.ams and fill in. GITIGNORED.
#
# Same trust boundary as AMS-stored secrets: it ships only inside the uploaded
# AMS image (build/ is gitignored), never to git.
AB_BASE_URL=https://seal-chessags.prod.gamingservices.accelbyte.io
AB_CLIENT_ID=4d98466a671d4172aa98f9a3f1fa29d1
AB_NAMESPACE=seal-chessags
MATCH_POOL=chess-quickmatch
BOT_EMAIL=
BOT_PASSWORD=
# Must match the Extend watcher's BOT_TRIGGER_SECRET (generate: openssl rand -hex 16).
BOT_TRIGGER_SECRET=
