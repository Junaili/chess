{
  "swagger": "2.0",
  "info": {
    "title": "Ethan Chess Service API",
    "version": "1.0"
  },
  "tags": [
    {
      "name": "ChessService"
    }
  ],
  "basePath": "/service",
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/invite/email": {
      "post": {
        "summary": "Send email invite",
        "description": "Send a chess invitation email to an unregistered user",
        "operationId": "ChessService_SendInvite",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/chessserviceSendInviteResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/chessserviceSendInviteRequest"
            }
          }
        ],
        "tags": [
          "ChessService"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/lookup/email": {
      "get": {
        "summary": "Look up user by email",
        "description": "Look up an AGS user account by email address using the admin IAM API",
        "operationId": "ChessService_LookupByEmail",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/chessserviceLookupByEmailResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ChessService"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    }
  },
  "definitions": {
    "chessserviceLookupByEmailResponse": {
      "type": "object",
      "properties": {
        "found": {
          "type": "boolean"
        },
        "userId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "chessserviceSendInviteRequest": {
      "type": "object",
      "properties": {
        "to": {
          "type": "string"
        },
        "fromName": {
          "type": "string"
        },
        "inviteLink": {
          "type": "string"
        }
      }
    },
    "chessserviceSendInviteResponse": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  },
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  }
}
