GMAIL_USER=you@gmail.com
GMAIL_APP_PW=xxxx xxxx xxxx xxxx

# AGS server-side IAM client (create a "Server" type client in the AGS portal)
# Required client permissions:
#   ADMIN:NAMESPACE:{namespace}:USER:*:ACHIEVEMENT [UPDATE]  (for /referral recruiter unlock)
#   ADMIN:NAMESPACE:{namespace}:USER:*  [READ]               (for email lookup)
#   ADMIN:NAMESPACE:{namespace}:USER:*  [CREATE]             (for parent-authorized child accounts)
#   ADMIN:NAMESPACE:{namespace}:USER:{userId} [READ]          (for linked login lookup)
#   ADMIN:NAMESPACE:{namespace}:S2S:INFORMATION:USER [CREATE] (for native GDPR deletion)
# Scope must include: social
AB_BASE_URL=https://seal-chessags.prod.gamingservices.accelbyte.io
AB_CLIENT_ID=
AB_CLIENT_SECRET=
AB_NAMESPACE=seal-chessags

# Sign in with Apple revocation for in-app account deletion. Keep these values
# in Extend secret configuration; never expose them through VITE_* variables.
# APPLE_PRIVATE_KEY_B64 is the base64-encoded contents of the Apple .p8 file.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=io.github.junaili.chess
APPLE_PRIVATE_KEY_B64=

# Club subscription + Ethan Coins (dev-plan/subscription-coins-implementation-plan.md).
# Additional AB_CLIENT_ID/SECRET permissions required, granted via the AGS
# Admin Portal's client "Permission Module" picker (Shared Cloud tier — NOT
# raw resource/action strings). Verified live 2026-07-13 against the
# ethan-chess-service client; module/group ids exactly as the portal names
# them:
#   Platform Store  -> Wallet             [selectedActions: READ, UPDATE]
#   Platform Store  -> Entitlement        [selectedActions: CREATE, READ, UPDATE]
#   Platform Store  -> Item               [selectedActions: CREATE, READ, UPDATE, DELETE]
#   Platform Store  -> Subscription       [selectedActions: CREATE, READ, UPDATE, DELETE]  (AGS-native Club subscriptions)
#   Statistics      -> User's Statistics Value [selectedActions: CREATE, READ, UPDATE, DELETE]  (kudos-received)
#   Cloud Save      -> Player Records     [selectedActions: CREATE, READ, UPDATE, DELETE]  (monetization ledger)
#   Cloud Save      -> Game Records       [selectedActions: CREATE, READ, UPDATE, DELETE]  (club-open-journal-config)
#   Groups          -> Group Member       [selectedActions: READ]  (family role lookups — see
#                                          monetization_family.go's file header: this AGS
#                                          deployment rejects the client's own S2S token for
#                                          Group calls entirely, so this permission is only
#                                          exercised via the CALLER's forwarded token, never
#                                          the client-credentials token directly)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Used for Stripe Checkout success/cancel redirect URLs and the customer
# portal return URL. No trailing slash.
WEB_BASE_URL=https://junaili.github.io/chess

# Comma-separated CORS allowlist. The default also permits the Capacitor origin.
ALLOWED_ORIGIN=https://junaili.github.io,capacitor://localhost

# Comma-separated hostnames accepted in emailed game links.
ALLOWED_INVITE_HOSTS=junaili.github.io

# Keep public API docs off unless actively debugging. (gRPC reflection is
# always on: the Admin Portal's Task Scheduler detection requires it.)
ENABLE_API_DOCS=false

PORT=8080
