.env
# Local-only LLM config for the bot trainer — never committed, never deployed.
# (Templates .env.example / .env.local.example are kept tracked.)
.env.local
.env.*.local
ethan-chess
dist/
build/
# Locally-built dev binaries (go build -o bot-ds / -o main)
/bot-ds
/main
# Local runtime config (server name, ports) — not for sharing
config.json
# Vim swap files
*.swp
# Local server session/debug logs
session/
# Local self-play dry-run dumps
bots/*/selfplay-*.json
