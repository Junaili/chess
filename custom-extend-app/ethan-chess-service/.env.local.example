# ─────────────────────────────────────────────────────────────────────────────
# LOCAL-ONLY config for the chess bot trainer (cmd/train-bot, cmd/spar).
#
# Copy this to `.env.local`. It is gitignored AND dockerignored, and is NEVER
# part of the deployed Extend service — the deployed app neither reads nor
# contains any LLM configuration. Training runs only locally, when you trigger
# the CLI. AGS credentials still come from the app's `.env` (shared).
# ─────────────────────────────────────────────────────────────────────────────

# Provider: anthropic | openai
LLM_PROVIDER=anthropic

# Model (optional — a sensible default is used per provider if unset)
# LLM_MODEL=claude-sonnet-4-6        # anthropic
# LLM_MODEL=gpt-4o-mini              # openai / ChatGPT

# API key — set the provider-specific var OR the generic LLM_API_KEY
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_API_KEY=

# ── Local model instead (Ollama / LM Studio / llama.cpp / vLLM) ───────────────
# These speak the OpenAI-compatible API, so use the openai provider + a base URL:
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# (LLM_API_KEY may be left empty for most local servers)

# ── Optional tuning ──────────────────────────────────────────────────────────
# LLM_TEMPERATURE=0.4
# LLM_MAX_TOKENS=2048
